# satori.toml — place at repo root (or ~/.satori/config.toml for global)
# g/p/r merge: global -> project -> repo; repo-level [[servers]] wins by name
#
# Optional: point to a shared project directory that contains its own satori.toml.
# Use when multiple repos belong to the same project (e.g. ~/Kouzou/projects/miyo/).
# Set by uncommenting the line below.
#
# project_dir = "~/Kouzou/projects/myproject"

[gateway]
# auto_register_mcp_json = false   # import .mcp.json servers at startup

[context]
# storage_dir = "repo"            # where db.sqlite/kb.sqlite/scanner.log live.
                                  # values: "repo" (default → <repoRoot>/satori/),
                                  # "project" (→ <project_dir>/satori/),
                                  # "global" (→ ~/.satori/data/),
                                  # "<bare-name>" (→ ~/.satori/projects/<name>/),
                                  # "/abs/path" or "~/path" (used as-is).
                                  # CLI override: --storage <value> or --project <name>.
# db_path = "db.sqlite"            # filename within storage_dir; abs paths used as-is
# kb_path = "kb.sqlite"            # filename within storage_dir; abs paths used as-is
# session_guide_max_bytes = 2048   # max XML snapshot size
# retain_days = 30                 # prune captures older than N days

[lifecycle]
# npx_startup_timeout_ms = 30000   # max ms to wait for npx server to start

[security]
# startup_scan = true              # scan server configs at startup
# runtime_scan = true              # scan tool arguments before every call
# return_scan = false              # scan tool responses (slower)
# audit_log = "scanner.log"        # filename within storage_dir; abs paths used as-is

# Downstream server examples:
# [[servers]]
# name = "filesystem"
# runtime = "npx"
# command = "@modelcontextprotocol/server-filesystem"
# args = ["/path/to/allowed/dir"]
# handler = "passthrough"          # default
# enabled = true

# External HTTP MCP server (Streamable HTTP transport, e.g. Kado / Obsidian)
# Headers support ${ENV_VAR} expansion so secrets stay out of the toml.
# [[servers]]
# name = "kado"
# runtime = "external"
# url = "http://127.0.0.1:23026/mcp"
# headers = { Authorization = "Bearer ${KADO_KEY}" }
# enabled = true
#
# Note: if Satori itself runs inside a container, replace 127.0.0.1 with
# host.docker.internal (and have the downstream server bind to a host-
# reachable interface, e.g. 0.0.0.0).
